<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="300dp"
    android:height="120dp"
    android:viewportWidth="300"
    android:viewportHeight="120">
    
    <!-- Full logo: compressed icon + text (text should be overlaid in layouts) -->
    <group android:translateX="30" android:translateY="60" android:scaleX="0.9" android:scaleY="0.8">
        <!-- Left stroke of V -->
        <path
            android:pathData="M -18,-30 L 0,36"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="8"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"/>
        
        <!-- Right stroke of V -->
        <path
            android:pathData="M 18,-30 L 0,36"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="8"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"/>
        
        <!-- Orange accent bar (as path) -->
        <path
            android:pathData="M -16,-31 h 32 v 2 h -32 z"
            android:fillColor="#FF7A00" />

        <!-- Keyhole Circle (as path using arcs) -->
        <path
            android:pathData="M 4,12 A 4,4 0 1,0 -4,12 A 4,4 0 1,0 4,12"
            android:fillColor="#FF7A00" />

        <!-- Keyhole Stem (as path) -->
        <path
            android:pathData="M -1.5,16 h 3 v 8 h -3 z"
            android:fillColor="#FF7A00" />
    </group>

    <!-- Placeholder: Text should be rendered with TextView over the vector for proper font support -->
</vector>
