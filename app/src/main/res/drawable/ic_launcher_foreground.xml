<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Wrapping everything in a group to handle scaling and centering properly -->
    <!-- We scale down to 0.8 and compress vertically to remove stretch -->
    <group 
        android:name="logo_group"
        android:translateX="10.8" 
        android:translateY="14.5"
        android:scaleX="0.8"
        android:scaleY="0.75">

        <!-- V-Shield Shape -->
        <path
            android:pathData="M54,16 L26,38 L26,62 C26,78 38,90 54,96 C70,90 82,78 82,62 L82,38 Z"
            android:fillColor="#FF7A00"/>

        <!-- Inner cutout -->
        <path
            android:pathData="M54,24 L32,42 L32,62 C32,74 41,84 54,89 C67,84 76,74 76,62 L76,42 Z"
            android:fillColor="#0A1F44"/>

        <!-- V arms -->
        <path
            android:pathData="M40,40 L54,72"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="7"
            android:strokeLineCap="round"
            android:fillColor="#00000000"/>
        <path
            android:pathData="M68,40 L54,72"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="7"
            android:strokeLineCap="round"
            android:fillColor="#00000000"/>

        <!-- Keyhole -->
        <path
            android:pathData="M54,55 m-5,0 a5,5 0,1 1,10 0 a5,5 0,1 1,-10 0"
            android:fillColor="#FF7A00"/>
        <path
            android:pathData="M52,60 L56,60 L55,68 L53,68 Z"
            android:fillColor="#FF7A00"/>
    </group>
</vector>
