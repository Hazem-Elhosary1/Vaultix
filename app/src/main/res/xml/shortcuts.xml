<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="add_password"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_password"
        android:shortcutShortLabel="@string/shortcut_add_password_short"
        android:shortcutLongLabel="@string/shortcut_add_password_long">
        <intent
            android:action="com.vaultix.app.ACTION_ADD_PASSWORD"
            android:targetPackage="com.vaultix.app"
            android:targetClass="com.vaultix.app.MainActivity" />
    </shortcut>
    <shortcut
        android:shortcutId="add_note"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_note"
        android:shortcutShortLabel="@string/shortcut_add_note_short"
        android:shortcutLongLabel="@string/shortcut_add_note_long">
        <intent
            android:action="com.vaultix.app.ACTION_ADD_NOTE"
            android:targetPackage="com.vaultix.app"
            android:targetClass="com.vaultix.app.MainActivity" />
    </shortcut>
